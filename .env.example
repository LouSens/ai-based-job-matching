# KerjaCerdas Environment Variables
# Copy this file to .env and fill in your values.
# RULE-01: Never commit .env to git.

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key-here

# Database
DATABASE_URL=postgresql://kerja:password@localhost:5432/kerjacerdas

# Redis
REDIS_URL=redis://localhost:6379/0

# Application
APP_ENV=development
DEMO_MODE=true
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# Authentication
# Optional in development. If omitted, the API generates an ephemeral runtime secret.
JWT_SECRET_KEY=replace-with-a-strong-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5001

# Frontend
VITE_API_URL=http://localhost:8000
