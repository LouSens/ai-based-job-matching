# ─── KerjaCerdas Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your values.
# RULE-01: Never commit .env to git.

# ─── Google Gemini API ────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://kerja:password@localhost:5432/kerjacerdas

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
DEMO_MODE=true
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# ─── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5001

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
